{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "baseUrl": ".",
    "moduleSuffixes": [".native", ".web", ""],
    "paths": {
      "@components/*": ["src/components/*"],
      "@screens/*": ["src/screens/*"],
      "@navigation/*": ["src/navigation/*"],
      "@hooks/*": ["src/hooks/*"],
      "@store/*": ["src/store/*"],
      "@theme/*": ["src/theme/*"],
      "@data/*": ["src/data/*"],
      "@services/*": ["src/services/*"],
      "@models/*": ["src/types/*"],
      "@utils/*": ["src/utils/*"]
    }
  }
}
